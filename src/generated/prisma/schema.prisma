datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  imcRecords ImcRecord[]
  createdAt  DateTime    @default(now())

  @@map("user")
}

model ImcRecord {
  id       String @id @default(uuid())
  weight   Float // peso em kg
  height   Float // altura em metros
  imc      Float // valor calculado
  category String // ex: "Normal", "Sobrepeso", etc

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
}
