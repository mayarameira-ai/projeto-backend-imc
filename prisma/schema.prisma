datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  imcRecords ImcRecord[]
  createdAt DateTime   @default(now())
}

model ImcRecord {
  id        Int      @id @default(autoincrement())
  weight    Float    // peso em kg
  height    Float    // altura em metros
  imc       Float    // valor calculado
  category  String   // ex: "Normal", "Sobrepeso", etc
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
}